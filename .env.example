# Images
POSTGRES_IMAGE=postgres:17.5-alpine
QDRANT_IMAGE=qdrant/qdrant:v1.17.1
NEO4J_IMAGE=neo4j:5.26.8
OPEN_WEBUI_IMAGE=ghcr.io/open-webui/open-webui:v0.9.5
OLLAMA_IMAGE=ollama/ollama:0.22.1
NODE_IMAGE=node:22.17.0-alpine
DOTNET_SDK_IMAGE=mcr.microsoft.com/dotnet/sdk:8.0
DOTNET_ASPNET_IMAGE=mcr.microsoft.com/dotnet/aspnet:8.0

# Ports
POSTGRES_PORT=5432
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
OPEN_WEBUI_PORT=3000
MCP_GATEWAY_PORT=7000
ADMIN_PORT=8080
OLLAMA_PORT=11434

# PostgreSQL
POSTGRES_DB=ai_platform
POSTGRES_USER=ai_platform
POSTGRES_PASSWORD=

# Qdrant
QDRANT_API_KEY=

# Neo4j
NEO4J_PASSWORD=

# Open WebUI
OPEN_WEBUI_SECRET_KEY=

# MCP Gateway
GATEWAY_API_KEY=

# Admin UI
ADMIN_API_KEY=

# Local LLM / Embeddings
LLM_PROVIDER=ollama
LOCAL_CHAT_MODEL=qwen2.5:7b-instruct
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_VECTOR_SIZE=768

# Indexing limits and resilience
EMBEDDING_MAX_CHARS=6000
EMBEDDING_MAX_LINES=80
EMBEDDING_TIMEOUT_MS=120000
EMBEDDING_MAX_RETRIES=2
ROSLYN_TIMEOUT_MS=45000
NEO4J_TIMEOUT_MS=60000
INDEX_FILE_TIMEOUT_MS=300000
INDEX_IGNORE_MIGRATIONS=true

# Persistent indexing queue (1-3)
INDEX_MAX_CONCURRENT_REPOSITORIES=1

# Git
GITHUB_TOKEN=
GITHUB_OWNER=
