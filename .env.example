# Versoes das imagens (atualizacao operacional)
POSTGRES_IMAGE=postgres:17.5-alpine
QDRANT_IMAGE=qdrant/qdrant:v1.17.1
NEO4J_IMAGE=neo4j:5.26.8
OPEN_WEBUI_IMAGE=ghcr.io/open-webui/open-webui:v0.10.2
DOCLING_IMAGE=quay.io/docling-project/docling-serve:v1.18.0
OLLAMA_IMAGE=ollama/ollama:0.22.1
NODE_IMAGE=node:22.17.0-alpine
DOTNET_SDK_IMAGE=mcr.microsoft.com/dotnet/sdk:8.0
DOTNET_ASPNET_IMAGE=mcr.microsoft.com/dotnet/aspnet:8.0

# Portas publicas
POSTGRES_PORT=5432
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
OPEN_WEBUI_PORT=3000
DOCLING_PORT=5001
MCP_GATEWAY_PORT=7000
ADMIN_PORT=8080
OLLAMA_PORT=11434

# Credenciais geradas automaticamente pelo install.sh
POSTGRES_PASSWORD=
QDRANT_API_KEY=
NEO4J_PASSWORD=
OPEN_WEBUI_SECRET_KEY=
GATEWAY_API_KEY=
# Opcional: tokens fixados por workspace, por exemplo {"claps":"segredo-claps"}
GATEWAY_WORKSPACE_KEYS_JSON=
ADMIN_API_KEY=

# Modelos locais (altere apenas se for usar outros modelos)
LOCAL_CHAT_MODEL=qwen2.5:7b-instruct
EMBEDDING_MODEL=qwen3-embedding:0.6b
EMBEDDING_VECTOR_SIZE=1024
RAG_EMBEDDING_QUERY_PREFIX="Instruct: Given a question in Portuguese or English, retrieve the passages from internal business and technical documents that best support a precise and factual answer.\nQuery: "

# Indexacao (em milissegundos; otimizados para modelos locais e repositorios grandes)
EMBEDDING_TIMEOUT_MS=300000
ROSLYN_TIMEOUT_MS=120000
NEO4J_TIMEOUT_MS=120000
INDEX_FILE_TIMEOUT_MS=1200000
INDEX_MAX_CONCURRENT_REPOSITORIES=1
RESEARCH_SESSION_TTL_MS=1200000
REPOSITORY_RECONCILER_ENABLED=true
REPOSITORY_RECONCILER_INTERVAL_MINUTES=60
REPOSITORY_RECONCILER_INITIAL_DELAY_SECONDS=60

# GitHub (opcional; necessario apenas para repositorios privados)
GITHUB_TOKEN=
GITHUB_OWNER=
